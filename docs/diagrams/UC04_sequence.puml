@startuml
title UC04 - Geracao de Relatorios de Qualidade (Sequencia)

actor Usuario
participant APP as "Aplicativo"
participant DB as "Base de Inspecoes"
participant REL as "Modulo Relatorios"
participant OUT as "Exportacao/Impressao"

Usuario -> APP : Solicitar relatorio com filtros
APP -> DB : Consultar inspecoes e nao conformidades
DB --> APP : Dados consolidados
APP -> REL : Gerar metricas e visualizacoes
REL --> APP : Relatorio montado
APP --> Usuario : Exibir relatorio

alt Exportar PDF
  Usuario -> APP : Exportar
  APP -> OUT : Gerar PDF
  OUT --> APP : Arquivo pronto
  APP --> Usuario : Download concluido
else
  APP --> Usuario : Encerrar sem exportacao
end

@enduml
