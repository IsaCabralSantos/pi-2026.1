@startuml
title UC01 - Inspecionar Peca Dimensionalmente (Atividades)

start
:Abrir aplicativo;
:Selecionar peca por codigo/OP;
:Buscar CAD correspondente;

if (CAD encontrado?) then (Sim)
  :Extrair dimensoes do CAD;
  :Exibir orientacao de captura;
  :Capturar imagem da peca;

  if (Imagem valida?) then (Sim)
    :Calcular medidas reais;
    :Comparar com CAD;
    :Validar tolerancias;

    if (Dentro da tolerancia?) then (Sim)
      :Definir resultado OK;
    else (Nao)
      :Definir resultado NOK;
      :Destacar dimensoes nao conformes;
    endif

    :Registrar inspecao;
    :Exibir feedback imediato;
    stop
  else (Nao)
    :Solicitar nova captura;
    :Capturar imagem da peca;
    :Calcular medidas reais;
    :Comparar com CAD;
    :Validar tolerancias;

    if (Dentro da tolerancia?) then (Sim)
      :Definir resultado OK;
    else (Nao)
      :Definir resultado NOK;
      :Destacar dimensoes nao conformes;
    endif

    :Registrar inspecao;
    :Exibir feedback imediato;
    stop
  endif
else (Nao)
  :Exibir erro de CAD nao encontrado;
  :Solicitar nova selecao;
  stop
endif

@enduml
